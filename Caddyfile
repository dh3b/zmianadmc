{$SITE_DOMAINS} {
	root * /srv
	rewrite /privacy-policy /privacy-policy.html

	# Language subdirectories: redirect no-trailing-slash to trailing-slash
	@langEn path /en
	redir @langEn /en/ 301

	@langRo path /ro
	redir @langRo /ro/ 301

	@langCs path /cs
	redir @langCs /cs/ 301

	@langIt path /it
	redir @langIt /it/ 301

	@langHu path /hu
	redir @langHu /hu/ 301

	@langEs path /es
	redir @langEs /es/ 301

	@langUk path /uk
	redir @langUk /uk/ 301

	@langRu path /ru
	redir @langRu /ru/ 301

	file_server

	@static path *.css *.js *.png *.jpg *.jpeg *.svg *.ico *.webp *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"

	@html path *.html / /en/ /ro/ /cs/ /it/ /hu/ /es/ /uk/ /ru/
	header @html Cache-Control "public, max-age=3600"
}
