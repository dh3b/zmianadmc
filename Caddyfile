{$SITE_DOMAINS} {
	root * /srv
	rewrite /privacy-policy /privacy-policy.html
	file_server

	@static path *.css *.js *.png *.jpg *.jpeg *.svg *.ico *.webp *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"

	@html path *.html /
	header @html Cache-Control "public, max-age=3600"
}
